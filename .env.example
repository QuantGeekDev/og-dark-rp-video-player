# Discord developer app — https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# The exact OAuth2 redirect URI registered in the Discord developer portal.
# Production: https://ogdarkrp.com/api/link-discord/oauth/callback
# Local dev:  http://localhost:3000/api/link-discord/oauth/callback
DISCORD_REDIRECT_URI=
# The numeric guild ID for our Discord server (https://discord.gg/b2ursP823g).
# Right-click the server icon with developer mode enabled to verify or update.
DISCORD_REQUIRED_GUILD_ID=1497692419729133661

# Public origin used to build the verify URL the gamemode shows the player.
# Production: https://ogdarkrp.com
# Local dev:  http://localhost:3000
LINK_BASE_URL=

# Symmetric secret shared with the S&Box gamemode. The gamemode sends it as
# the `x-link-secret` header on every issue/status request, and the server
# uses the same secret to HMAC-sign the OAuth `state` parameter.
# Generate with: openssl rand -hex 32
LINK_SHARED_SECRET=

# Provisioned automatically by the Vercel Marketplace Upstash integration.
KV_REST_API_URL=
KV_REST_API_TOKEN=
